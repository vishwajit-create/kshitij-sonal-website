# Ignore everything that doesn't need to be in the image

# Version control
.git
.gitignore

# Environment files (secrets - never bake into image)
.env
.env.*
!.env.example

# Dev dependencies already handled by npm ci --omit=dev
node_modules

# Railway / Heroku deployment files (not needed in Docker)
Procfile
railway.json

# Logs
*.log
npm-debug.log*

# OS junk
.DS_Store
Thumbs.db
